# Treat binary files as binary so Git does not corrupt them on line-ending normalization (CRLF/LF)
*.jar binary
*.png binary
*.jpg binary
*.webp binary
*.keystore binary
*.bin binary
*.zip binary

# Ensure standard text normalization for source files
*.kt text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
